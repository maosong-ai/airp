      "children": [
        {
          "type": "lead",
          "text": "本节给出可直接落地的测试对象清单、测试观点与边界。每个对象至少覆盖：正常路径、边界输入、错误输入、回归场景。"
        },
        {
          "type": "table",
          "caption": "单元测试范围（函数/模块级）",
          "columns": [
            {
              "key": "target",
              "label": "测试对象"
            },
            {
              "key": "scope",
              "label": "范围（接口/函数）"
            },
            {
              "key": "viewpoint",
              "label": "测试观点"
            },
            {
              "key": "method",
              "label": "方法"
            },
            {
              "key": "boundary",
              "label": "关键边界"
            }
          ],
          "rows": [
            {
              "target": "AIRP 解析与 Schema",
              "scope": "parseAirpDocument / airpDocumentSchema / blockSchema",
              "viewpoint": "输入合法性与错误可解释性",
              "method": "等价类 + 边界值 + 非法字段注入 + 缺字段",
              "boundary": "schemaVersion、blocks 最小长度、枚举值、递归 block 结构"
            },
            {
              "target": "国际化选择与回退",
              "scope": "normalizeLocale / pickLocale / resolveLocalized / resolveRichText",
              "viewpoint": "locale 规范化与 fallback 稳定性",
              "method": "参数化测试 + 回退链断言",
              "boundary": "preferred 缺失、区域码大小写、locale 不存在、空对象"
            },
            {
              "target": "目录与锚点生成",
              "scope": "collectToc / slugify",
              "viewpoint": "结构遍历正确性与可预测 ID",
              "method": "树形夹具 + 递归深度场景",
              "boundary": "section/group/tabs/collapsible/appendix 混合嵌套"
            },
            {
              "target": "Markdown 生成核心",
              "scope": "emitBlock / emitBlocks / emitDocument",
              "viewpoint": "块类型映射正确性与 Markdown 语义稳定",
              "method": "golden 文本断言 + 最小快照",
              "boundary": "table 转义、comparison bullet 特判、heading level 截断"
            },
            {
              "target": "导出文件名与安全处理",
              "scope": "artifactFilename / escapeInlineScript",
              "viewpoint": "可用文件名与脚本注入防护",
              "method": "字符集 fuzz 样本 + 特殊字符断言",
              "boundary": "中英文混排、超长标题、空标题、</script> 片段"
            },
            {
              "target": "渲染编排",
              "scope": "registerBackend / renderDocument",
              "viewpoint": "后端注册机制与异常路径",
              "method": "mock backend + 异常断言",
              "boundary": "未注册 target、重复注册覆盖、render 抛错透传"
            }
          ]
        },
        {
          "type": "table",
          "caption": "集成测试范围（命令/流程级）",
          "columns": [
            {
              "key": "flow",
              "label": "测试流程"
            },
            {
              "key": "entry",
              "label": "入口（命令行）"
            },
            {
              "key": "assertion",
              "label": "核心断言"
            },
            {
              "key": "negative",
              "label": "反向场景"
            }
          ],
          "rows": [
            {
              "flow": "文档校验流程",
              "entry": "pnpm validate <input.airp.json>",
              "assertion": "合法文档 exit code=0 且输出 OK",
              "negative": "非法 schema/字段时 exit code=1 且报错可定位"
            },
            {
              "flow": "Markdown 导出流程",
              "entry": "pnpm render:markdown <input> --locale <code> -o <out>",
              "assertion": "生成 .md 文件，标题/分节/表格内容与 locale 对应",
              "negative": "缺失 --locale 或 locale 非法时 fail-closed"
            },
            {
              "flow": "HTML 导出流程",
              "entry": "pnpm render:html <input> --locale-mode <all|single> [--single-locale]",
              "assertion": "生成自包含 HTML，含样式与脚本内联，localeMode 行为正确",
              "negative": "locale-mode 非法、single 但缺 locale、all 误传 single-locale"
            },
            {
              "flow": "i18n 单语言/多语言参数-输出匹配",
              "entry": "render:html 与 render:markdown 参数组合",
              "assertion": "导出参数、文档 i18n 配置与输出文件内容三者一致",
              "negative": "参数与文档 locale 集不匹配时必须 fail-closed"
            },
            {
              "flow": "Skill CLI 编译产物验证（compile-first）",
              "entry": "node scripts/build-validate-airp.mjs && node scripts/build-render-markdown.mjs && node scripts/build-render-html.mjs",
              "assertion": "成功生成 skills/*/scripts/*.mjs，并可由 node 直接执行完成 validate/render",
              "negative": "esbuild 缺失、构建失败、bundle 超限、产物缺失时必须失败并输出可诊断错误"
            },
            {
              "flow": "渲染管线流程",
              "entry": "loadDocumentFromPath -> renderDocument(markdown/html)",
              "assertion": "artifact 的 format/mimeType/filename/body 一致",
              "negative": "未注册后端或 locale 不在文档范围时明确报错"
            }
          ]
        },
